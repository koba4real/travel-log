NODE_ENV=development
# Local dev: a SQLite file managed by @libsql/client (created by `pnpm db:migrate`).
# Production (Turso cloud): an https/libsql URL, e.g. libsql://<db>-<org>.turso.io
TURSO_DATABASE_URL=file:local.db
TURSO_AUTH_TOKEN=
# Places search (Nominatim / OpenStreetMap). No API key required, but its usage
# policy requires an identifying User-Agent. Optional — has a default in nuxt.config.
NUXT_NOMINATIM_USER_AGENT=
