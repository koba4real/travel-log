NODE_ENV=development

# Database -------------------------------------------------------------------
# Local dev: a SQLite file managed by @libsql/client (created by `pnpm db:migrate`).
# Production (Turso cloud): an https/libsql URL, e.g. libsql://<db>-<org>.turso.io
TURSO_DATABASE_URL=file:local.db
# Required only when NODE_ENV=production (ignored for local file: URLs).
TURSO_AUTH_TOKEN=

# Auth (Better Auth + GitHub OAuth) ------------------------------------------
# Random 32+ char string, e.g. `openssl rand -base64 32`.
BETTER_AUTH_SECRET=
# App base URL. Must match your GitHub OAuth app callback host.
BETTER_AUTH_URL=http://localhost:3000
# From your GitHub OAuth app. Callback URL: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_CLIENT_ID=
AUTH_GITHUB_CLIENT_SECRET=

# Image storage (S3-compatible) ----------------------------------------------
# Defaults below match the local MinIO container in docker-compose.yml.
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_ACCESS_SECRET=minioadmin
S3_REGION=us-east-1
S3_BUCKET=travel-log
# Public read URL for uploaded objects (used to build image src URLs).
S3_BUCKET_URL=http://localhost:9000/travel-log

# Local MinIO container (read by docker-compose.yml) -------------------------
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Places search (Nominatim / OpenStreetMap). No API key required, but its usage
# policy requires an identifying User-Agent. Optional — has a default in nuxt.config.
NUXT_NOMINATIM_USER_AGENT=
